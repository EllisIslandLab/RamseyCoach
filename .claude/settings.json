{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && npx tsc --noEmit 2>&1 | head -20; true"
          }
        ]
      }
    ]
  },

  "permissions": {
    "deny": [
      "Read(.env.local)"
    ]
  },

  "fileSettings": {
    "ignorePatterns": [
      ".next/**",
      "node_modules/**",
      ".git/**",
      "coverage/**",
      "*.log",
      ".env.local",
      "out/**",
      "dist/**"
    ]
  },

  "project": {
    "name": "Money-Willo",
    "type": "next.js",
    "language": "TypeScript",
    "framework": "Next.js (Pages Router) with React",
    "database": "Supabase (PostgreSQL)",
    "styling": "Tailwind CSS",
    "email": "Resend",
    "description": "Personal finance coaching web app — budget planner, shared access, accountability partners"
  }
}
